## Credit System Module 4 pack plans starter $5 pro $15 premium $25 costom $45 
**Purpose**: Add to any existing app. $0.05/credit. No free tier. Blocks actions when balance = 0.
### Supabase Tables
```sql
create table credit_wallets (
  id uuid default uuid_generate_v4() primary key,
  user_id uuid references auth.users(id),
  balance numeric(10,4) default 0
);

create table credit_transactions (
  id uuid default uuid_generate_v4() primary key,
  user_id uuid references auth.users(id),
  amount numeric(10,4),
  reason text,
  reference_id uuid
);

create table pricing_rules (
  id uuid default uuid_generate_v4() primary key,
  action_type text unique,
  base_cost_credits numeric(8,4) default 1.0
);

insert into pricing_rules (action_type, base_cost_credits) values
('ai_message', 1),
('ai_build', 20),
('deploy_vercel', 40),
('deploy_netlify', 40);
```

