### API Routes (/api/credits/)

**check** - `POST`
```ts
export async function POST(req) {
  const { user } = await getUser();
  const { actionType } = await req.json();
  
  const { data } = await supabase
    .from('credit_wallets')
    .select('balance')
    .eq('user_id', user.id)
    .single();
    
  const rule = await supabase
    .from('pricing_rules')
    .select('base_cost_credits')
    .eq('action_type', actionType)
    .single();
    
  return Response.json({
    balance: data?.balance || 0,
    cost: rule?.base_cost_credits || 1,
    sufficient: (data?.balance || 0) >= (rule?.base_cost_credits || 1)
  });
}
```

**usage** - `POST` (call before every action)
```ts
export async function POST(req) {
  const { user } = await getUser();
  const { actionType, referenceId } = await req.json();
  
  const rule = await supabase
    .from('pricing_rules')
    .select('base_cost_credits')
    .eq('action_type', actionType)
    .single();
    
  const cost = rule?.base_cost_credits || 1;
  const { data: wallet } = await supabase
    .from('credit_wallets')
    .select('balance')
    .eq('user_id', user.id)
    .single();
    
  if ((wallet?.balance || 0) < cost) {
    return Response.json({ error: 'Insufficient credits' }, { status: 402 });
  }
  
  // Atomic deduct
  await supabase.from('credit_transactions').insert({
    user_id: user.id,
    amount: -cost,
    reason: actionType,
    reference_id: referenceId
  });
  
  await supabase
    .from('credit_wallets')
    .update({ balance: wallet.balance - cost })
    .eq('user_id', user.id);
    
  return Response.json({ success: true });
}
```

### Usage Pattern
```ts
// Before any paid action
const check = await fetch('/api/credits/check', {
  method: 'POST',
  body: JSON.stringify({ actionType: 'ai_build' })
});

if (!check.sufficient) {
  // Show topup modal
  return;
}

// Then do the action
await fetch('/api/credits/usage', {
  method: 'POST',
  body: JSON.stringify({ actionType: 'ai_build', referenceId: buildId })
});

// Proceed with build/deploy/whatever
```

